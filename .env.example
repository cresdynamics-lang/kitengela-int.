# Copy to .env in repo root or to apps/api/.env and apps/web/.env.local as needed.
# For Vercel: set only DATABASE_URL (and optionally RESEND_API_KEY) in the dashboard.
# Do not commit real values.

# -----------------------------------------------------------------------------
# Shared / Database (used by apps/api and apps/web on Vercel)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:password@localhost:5432/database"

# -----------------------------------------------------------------------------
# Local API (apps/api) – not needed when running only apps/web on Vercel
# -----------------------------------------------------------------------------
REDIS_URL="redis://localhost:6379"
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-token-key-change-in-production"
CORS_ORIGIN="http://localhost:3000"

# -----------------------------------------------------------------------------
# Frontend (Vite app)
# -----------------------------------------------------------------------------
# For local dev with separate API server (Express on port 3001, or Supabase edge functions URL):
#   VITE_API_URL="http://localhost:3001"
# For production on Vercel:
#   - If your API is deployed elsewhere (Render/Railway/Supabase Functions/etc.),
#     set VITE_API_URL to that base URL, e.g. "https://my-api.example.com"
#   - Then set the same VITE_API_URL in Vercel → Project → Environment Variables
VITE_API_URL="http://localhost:3001"

NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Wednesday Online Prayers – YouTube video (ID or full embed URL). Leave empty to show image.
# VITE_WEDNESDAY_PRAYER_VIDEO_URL="your-youtube-video-id"

# Contact form (Resend) – optional; set RESEND_API_KEY on Vercel if you use it
# RESEND_API_KEY=""

# -----------------------------------------------------------------------------
# Cloudinary (optional, for image uploads)
# -----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"
CLOUDINARY_UPLOAD_PRESET="vosh-kitengela"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"

# -----------------------------------------------------------------------------
# Admin default (for seeding / first login – change after first login)
# -----------------------------------------------------------------------------
ADMIN_USERNAME="admin"
ADMIN_EMAIL="admin@voshkitengela.org"
ADMIN_PASSWORD="admin123"
