# Copy to .env in repo root or to apps/api/.env and apps/web/.env.local as needed.
# For Vercel: set only DATABASE_URL (and optionally RESEND_API_KEY) in the dashboard.
# Do not commit real values.

# -----------------------------------------------------------------------------
# Shared / Database (used by apps/api and apps/web on Vercel)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:password@localhost:5432/database"

# -----------------------------------------------------------------------------
# Local API (apps/api) – not needed when running only apps/web on Vercel
# -----------------------------------------------------------------------------
REDIS_URL="redis://localhost:6379"
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-token-key-change-in-production"
CORS_ORIGIN="http://localhost:3000"

# -----------------------------------------------------------------------------
# Next.js / Frontend (apps/web)
# -----------------------------------------------------------------------------
# For local dev with separate API: set to http://localhost:3001
# On Vercel: leave unset so the site uses built-in /api
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Contact form (Resend) – optional; set RESEND_API_KEY on Vercel if you use it
# RESEND_API_KEY=""

# -----------------------------------------------------------------------------
# Cloudinary (optional, for image uploads)
# -----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"
CLOUDINARY_UPLOAD_PRESET="vosh-kitengela"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"

# -----------------------------------------------------------------------------
# Admin default (for seeding / first login – change after first login)
# -----------------------------------------------------------------------------
ADMIN_USERNAME="admin"
ADMIN_EMAIL="admin@voshkitengela.org"
ADMIN_PASSWORD="admin123"
